# ─── Core Paths ───
db_path=trebek.db                     # Path to the SQLite database
output_dir=gpu_outputs                # Directory for intermediate pipeline outputs (.json.gz)
input_dir=input_videos                # Directory to poll for new video files

# ─── API Keys ───
# Get your free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=                       # Google Gemini API key (required for LLM extraction stages)

# Required for WhisperX speaker diarization (free)
# 1. Accept license: https://huggingface.co/pyannote/speaker-diarization-3.1
# 2. Generate token: https://huggingface.co/settings/tokens
HF_TOKEN=                             # HuggingFace token (required for speaker diarization)

# ─── Logging ───
log_level=INFO                        # DEBUG, INFO, WARNING, ERROR

# ─── GPU Constraints ───
gpu_vram_target_gb=16                 # Target VRAM ceiling (4–24 GB)
whisper_batch_size=8                  # WhisperX batch size (8 = safe for 16GB; max ~16)
whisper_compute_type=float16          # float16 or float32
